<mxfile host="Electron" agent="agent-memory-system">
  <diagram id="event-flow" name="事件流转流程">
    <mxGraphModel dx="2175" dy="1115" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;" value="Agent Memory System - 事件从产生到消费的流转图" vertex="1">
          <mxGeometry height="40" width="720" x="220" y="20" as="geometry" />
        </mxCell>
        <mxCell id="prodBox" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=13;fillColor=#e8f4fd;strokeColor=#4a90d9;align=center;spacingTop=8;" value="① 事件生产者（业务服务）" vertex="1">
          <mxGeometry height="120" width="1000" x="80" y="90" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90d9;fontSize=12;" value="memory_fragment_service&#xa;创建 / 更新 / 删除" vertex="1">
          <mxGeometry height="60" width="220" x="110" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90d9;fontSize=12;" value="recall_engine&#xa;召回 recalled" vertex="1">
          <mxGeometry height="60" width="200" x="350" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90d9;fontSize=12;" value="memory_lifecycle_service&#xa;衰减 / 合并 / 冷标记 / 删除 / 恢复" vertex="1">
          <mxGeometry height="60" width="260" x="570" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a90d9;fontSize=12;" value="auto_recall_service /&#xa;context_compressor" vertex="1">
          <mxGeometry height="60" width="200" x="850" y="130" as="geometry" />
        </mxCell>
        <mxCell id="rte" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a90d9;fontStyle=1;fontSize=13;" value="record_trace_event()&#xa;（memory_observability_service）" vertex="1">
          <mxGeometry height="60" width="300" x="430" y="250" as="geometry" />
        </mxCell>
        <mxCell id="writeBox" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=13;fillColor=#f5f5f5;strokeColor=#999999;align=center;spacingTop=8;dashed=1;" value="② 写入 + 封装" vertex="1">
          <mxGeometry height="110" width="700" x="230" y="350" as="geometry" />
        </mxCell>
        <mxCell id="db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" value="SQLite / PostgreSQL&#xa;memory_trace_events 表&#xa;（持久化落库）" vertex="1">
          <mxGeometry height="70" width="220" x="270" y="380" as="geometry" />
        </mxCell>
        <mxCell id="evt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;" value="MemoryEvent.from_trace_event()&#xa;封装为统一事件对象&#xa;(event_type/user_id/memory_id/data...)" vertex="1">
          <mxGeometry height="70" width="270" x="620" y="380" as="geometry" />
        </mxCell>
        <mxCell id="pub" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" value="event_bus.publish(event)&#xa;fire-and-forget&#xa;loop.create_task(...)&#xa;※ 失败不影响主流程" vertex="1">
          <mxGeometry height="120" width="220" x="470" y="500" as="geometry" />
        </mxCell>
        <mxCell id="busBox" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=13;fillColor=#fff3e0;strokeColor=#e8a33d;align=center;spacingTop=8;" value="③ EventBus（按 EVENT_BUS_BACKEND 二选一，接口统一）" vertex="1">
          <mxGeometry height="130" width="860" x="150" y="660" as="geometry" />
        </mxCell>
        <mxCell id="mem" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="InMemoryEventBus（dev / 单进程）&#xa;· 环形缓冲区 10000 条&#xa;· asyncio.Queue 分发给订阅者" vertex="1">
          <mxGeometry height="70" width="360" x="180" y="700" as="geometry" />
        </mxCell>
        <mxCell id="redis" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="RedisEventBus（prod / 多进程）&#xa;· Redis Pub/Sub 跨进程分发&#xa;· Redis Stream 持久化最近事件" vertex="1">
          <mxGeometry height="70" width="360" x="600" y="700" as="geometry" />
        </mxCell>
        <mxCell id="consBox" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=13;fillColor=#e8f8ee;strokeColor=#52b788;align=center;spacingTop=8;" value="④ 事件消费者" vertex="1">
          <mxGeometry height="130" width="1000" x="80" y="840" as="geometry" />
        </mxCell>
        <mxCell id="c1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#52b788;fontSize=12;" value="SSE 实时流&#xa;GET /api/v1/events/stream&#xa;subscribe() 回调 → 推送前端" vertex="1">
          <mxGeometry height="70" width="290" x="110" y="880" as="geometry" />
        </mxCell>
        <mxCell id="c2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#52b788;fontSize=12;" value="历史查询&#xa;GET /api/v1/events&#xa;读环形缓冲 / Redis Stream" vertex="1">
          <mxGeometry height="70" width="290" x="440" y="880" as="geometry" />
        </mxCell>
        <mxCell id="c3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#52b788;fontSize=12;" value="Prometheus 指标&#xa;event_bus_published_total&#xa;（publish 时计数）" vertex="1">
          <mxGeometry height="70" width="280" x="770" y="880" as="geometry" />
        </mxCell>
        <mxCell id="fe" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a90d9;fontStyle=1;fontSize=13;" value="前端浏览器 EventSource&#xa;实时看板 / 事件时间线" vertex="1">
          <mxGeometry height="60" width="290" x="150" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="e_p1" edge="1" parent="1" source="p1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#4a90d9;" target="rte">
