        <mxCell id="e_pub" edge="1" parent="1" source="evt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#b85450;fontSize=11;" target="pub" value="3. 异步发布">
          <mxGeometry relative="1" as="geometry" />
