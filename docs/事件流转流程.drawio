        <mxCell id="e_fe" edge="1" parent="1" source="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeWidth=2;strokeColor=#4a90d9;fontSize=11;" target="fe" value="SSE 推送">
