        <mxCell id="e_evt" edge="1" parent="1" source="rte" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#999999;fontSize=11;" target="evt" value="2. 再封装">
          <mxGeometry relative="1" as="geometry" />
