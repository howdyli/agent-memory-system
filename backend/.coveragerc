[run]
source = app
omit =
    */tests/*
    */__pycache__/*
    */test_*
    */venv/*
    */env/*
    */site-packages/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

fail_under = 0
show_missing = True
