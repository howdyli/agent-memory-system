{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "HTTP 请求量 (QPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(http_requests_total[5m])",
        "legendFormat": "{{method}} {{handler}}"
      }]
    },
    {
      "title": "HTTP 延迟 P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "P99"
      }]
    },
    {
      "title": "HTTP 错误率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
        "legendFormat": "5xx Error Rate"
      }]
    },
    {
      "title": "记忆操作量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "rate(agent_memory_operations_total[5m])",
        "legendFormat": "{{operation}} - {{memory_type}}"
      }]
    },
    {
      "title": "召回延迟 P50/P95/P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(agent_memory_recall_latency_seconds_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(agent_memory_recall_latency_seconds_bucket[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(agent_memory_recall_latency_seconds_bucket[5m]))", "legendFormat": "P99" }
      ]
    },
    {
      "title": "召回命中率",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [{
        "expr": "agent_memory_recall_hit_rate",
        "legendFormat": "Hit Rate"
      }],
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "thresholds": { "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}] } } }
    },
    {
      "title": "活跃记忆数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{
        "expr": "agent_memory_active_count",
        "legendFormat": "{{memory_type}}"
      }]
    },
    {
      "title": "向量搜索延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(agent_memory_vector_search_latency_seconds_bucket[5m]))",
        "legendFormat": "P95 - {{backend}}"
      }]
    },
    {
      "title": "LLM Token 消耗",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [{
        "expr": "rate(agent_memory_llm_tokens_total[5m])",
        "legendFormat": "{{operation}} - {{token_type}}"
      }]
    },
    {
      "title": "Webhook 投递成功率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [{
        "expr": "rate(agent_memory_webhook_deliveries_total{status=\"success\"}[10m]) / rate(agent_memory_webhook_deliveries_total[10m])",
        "legendFormat": "Success Rate"
      }]
    },
    {
      "title": "事件发布速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [{
        "expr": "rate(agent_memory_events_published_total[5m])",
        "legendFormat": "{{event_type}}"
      }]
    },
    {
      "title": "事件订阅者数量",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [{
        "expr": "agent_memory_event_subscribers",
        "legendFormat": "Subscribers"
      }]
    },
    {
      "title": "生命周期操作量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "targets": [{
        "expr": "rate(agent_memory_lifecycle_actions_total[5m])",
        "legendFormat": "{{action}}"
      }]
    },
    {
      "title": "混合检索延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(agent_memory_hybrid_search_seconds_bucket[5m]))",
        "legendFormat": "P95"
      }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["agent-memory"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
